# Dominio publicado — usado en sitemap, OG, manifest
NEXT_PUBLIC_SITE_URL=https://pokehub.vercel.app

# ─── Supabase ───────────────────────────────────────────────────────────
# (auth + cloud save de equipos/favoritos)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Solo SERVIDOR — NO usar prefijo NEXT_PUBLIC_
# Necesario para el panel /admin (bypassa RLS, acceso a auth.users, etc).
# Supabase Dashboard → Settings → API → "service_role" "secret" key
SUPABASE_SERVICE_ROLE_KEY=

# ─── Admin Panel ────────────────────────────────────────────────────────
# Lista de emails con acceso a /admin separados por coma.
# Es NEXT_PUBLIC_ porque solo controla la visibilidad del menú; las
# operaciones reales se verifican server-side.
NEXT_PUBLIC_ADMIN_EMAILS=cristianlopezponce17@gmail.com

# ─── Anthropic ──────────────────────────────────────────────────────────
# Opcional, activa /api/recommend (IA Pokémon)
ANTHROPIC_API_KEY=
